generator client {
  provider        = "prisma-client-js"
  output          = "../prisma-client"
  previewFeatures = ["multiSchema"]
  binaryTargets   = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["audit", "booking", "catalog", "checkin", "identity", "payments", "public"]
}

model Country {
  id           String    @id @default(cuid())
  name         String    @unique
  isoCode      String    @unique @map("iso_code")
  phoneCode    String?   @map("phone_code")
  currencyCode String?   @map("currency_code")
  airlines     Airline[]
  cities       City[]

  @@map("countries")
  @@schema("catalog")
}

model City {
  id              String           @id @default(cuid())
  name            String
  countryId       String           @map("country_id")
  iataCode        String?          @unique @map("iata_code")
  airports        Airport[]
  country         Country          @relation(fields: [countryId], references: [id])
  users           User[]
  billingProfiles BillingProfile[]

  @@map("cities")
  @@schema("catalog")
}

model User {
  id               String           @id @default(cuid())
  email            String           @unique
  passwordHash     String           @map("password_hash")
  firstName        String           @map("first_name")
  secondName       String?          @map("second_name")
  firstLastName    String           @map("first_last_name")
  secondLastName   String?          @map("second_last_name")
  mainAddress      String           @map("main_address")
  secondaryAddress String?          @map("secondary_address")
  cityId           String           @map("city_id")
  phone            String?
  birthDate        DateTime?        @map("birth_date")
  role             UserRole         @default(CUSTOMER)
  isActive         Boolean          @default(true) @map("is_active")
  tokenVersion     Int              @default(0) @map("token_version")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")
  auditLogs        AuditLog[]
  reservations     Reservation[]
  city             City             @relation(fields: [cityId], references: [id])
  billingProfiles  BillingProfile[]

  @@map("users")
  @@schema("identity")
}

model BillingProfile {
  id           String    @id @default(cuid())
  userId       String    @map("user_id")
  taxId        String    @map("tax_id")
  businessName String    @map("business_name")
  email        String?
  address      String
  cityId       String    @map("city_id")
  isDefault    Boolean   @default(false) @map("is_default")
  city         City      @relation(fields: [cityId], references: [id])
  user         User      @relation(fields: [userId], references: [id])
  invoices     Invoice[]

  @@map("billing_profiles")
  @@schema("payments")
}

model Invoice {
  id               String         @id @default(cuid())
  paymentId        String         @unique @map("payment_id")
  billingProfileId String         @map("billing_profile_id")
  invoiceNumber    String         @unique @map("invoice_number")
  subtotal         Decimal        @db.Decimal(10, 2)
  taxAmount        Decimal        @map("tax_amount") @db.Decimal(10, 2)
  total            Decimal        @db.Decimal(10, 2)
  createdAt        DateTime       @default(now()) @map("created_at")
  items            InvoiceItem[]
  billingProfile   BillingProfile @relation(fields: [billingProfileId], references: [id])
  payment          Payment        @relation(fields: [paymentId], references: [id])

  @@map("invoices")
  @@schema("payments")
}

model InvoiceItem {
  id          String  @id @default(cuid())
  invoiceId   String  @map("invoice_id")
  description String
  quantity    Int     @default(1)
  unitPrice   Decimal @map("unit_price") @db.Decimal(10, 2)
  totalPrice  Decimal @map("total_price") @db.Decimal(10, 2)
  invoice     Invoice @relation(fields: [invoiceId], references: [id])

  @@map("invoice_items")
  @@schema("payments")
}

model Airport {
  id                  String           @id @default(cuid())
  iataCode            String           @unique @map("iata_code")
  name                String
  cityId              String           @map("city_id")
  timezone            String
  airlineAirports     AirlineAirport[]
  city                City             @relation(fields: [cityId], references: [id])
  destinationSegments Segment[]        @relation("DestinationAirport")
  originSegments      Segment[]        @relation("OriginAirport")

  @@map("airports")
  @@schema("catalog")
}

model Airline {
  id              String                 @id @default(cuid())
  iataCode        String                 @unique @map("iata_code")
  name            String
  logoUrl         String?                @map("logo_url")
  countryId       String                 @map("country_id")
  aircrafts       Aircraft[]
  airlineAirports AirlineAirport[]
  serviceConfigs  AirlineServiceConfig[]
  country         Country                @relation(fields: [countryId], references: [id])
  segments        Segment[]

  @@map("airlines")
  @@schema("catalog")
}

model Aircraft {
  id           String    @id @default(cuid())
  airlineId    String    @map("airline_id")
  modelName    String    @map("model_name")
  registration String    @unique
  hasWifi      Boolean   @default(false) @map("has_wifi")
  hasUsb       Boolean   @default(false) @map("has_usb")
  airline      Airline   @relation(fields: [airlineId], references: [id])
  segments     Segment[]

  @@map("aircrafts")
  @@schema("catalog")
}

model AirlineAirport {
  airlineId String  @map("airline_id")
  airportId String  @map("airport_id")
  airline   Airline @relation(fields: [airlineId], references: [id])
  airport   Airport @relation(fields: [airportId], references: [id])

  @@id([airlineId, airportId])
  @@map("airline_airports")
  @@schema("catalog")
}

model Flight {
  id                     String        @id @default(cuid())
  originAirportIata      String        @map("origin_airport_iata")
  destinationAirportIata String        @map("destination_airport_iata")
  departureDate          DateTime      @map("departure_date")
  status                 FlightStatus  @default(SCHEDULED)
  reservations           Reservation[]
  flightClasses          FlightClass[]
  segments               Segment[]

  @@index([departureDate, originAirportIata, destinationAirportIata])
  @@map("flights")
  @@schema("catalog")
}

model Segment {
  id                   String         @id @default(cuid())
  segmentNumber        String         @map("segment_number")
  originAirportId      String         @map("origin_airport_id")
  destinationAirportId String         @map("destination_airport_id")
  departureDateTime    DateTime       @map("departure_datetime")
  arrivalDateTime      DateTime       @map("arrival_datetime")
  airlineId            String         @map("airline_id")
  aircraftId           String?        @map("aircraft_id")
  estimatedDuration    Int            @map("estimated_duration")
  flightId             String?        @map("flight_id")
  aircraft             Aircraft?      @relation(fields: [aircraftId], references: [id])
  airline              Airline        @relation(fields: [airlineId], references: [id])
  destinationAirport   Airport        @relation("DestinationAirport", fields: [destinationAirportId], references: [id])
  flight               Flight?        @relation(fields: [flightId], references: [id])
  originAirport        Airport        @relation("OriginAirport", fields: [originAirportId], references: [id])
  boardingPasses       BoardingPass[]

  @@map("segments")
  @@schema("catalog")
}

model ServiceCatalog {
  id             String                 @id @default(cuid())
  name           String
  code           String                 @unique
  category       String
  description    String?
  airlineConfigs AirlineServiceConfig[]

  @@map("service_catalog")
  @@schema("catalog")
}

model AirlineServiceConfig {
  id                String             @id @default(cuid())
  serviceId         String             @map("service_id")
  airlineId         String             @map("airline_id")
  originAirportId   String?            @map("origin_airport_id")
  destAirportId     String?            @map("dest_airport_id")
  price             Decimal            @db.Decimal(10, 2)
  currency          String             @default("USD")
  passengerServices PassengerService[]
  airline           Airline            @relation(fields: [airlineId], references: [id])
  service           ServiceCatalog     @relation(fields: [serviceId], references: [id])

  @@map("airline_service_configs")
  @@schema("catalog")
}

model Reservation {
  id              String                 @id @default(cuid())
  userId          String                 @map("user_id")
  flightId        String                 @map("flight_id")
  promotionId     String?                @map("promotion_id")
  reservationCode String                 @unique @map("reservation_code")
  totalAmount     Decimal                @map("total_amount") @db.Decimal(10, 2)
  status          ReservationStatus      @default(PENDING)
  createdAt       DateTime               @default(now()) @map("created_at")
  passengers      ReservationPassenger[]
  flight          Flight                 @relation(fields: [flightId], references: [id])
  promotion       Promotion?             @relation(fields: [promotionId], references: [id])
  user            User                   @relation(fields: [userId], references: [id])
  payment         Payment?

  @@map("reservations")
  @@schema("booking")
}

model FlightClass {
  id                    String                 @id @default(cuid())
  flightId              String                 @map("flight_id")
  cabinClass            CabinClass             @map("cabin_class")
  availableSeats        Int                    @map("available_seats")
  basePrice             Decimal                @map("base_price") @db.Decimal(10, 2)
  reservationPassengers ReservationPassenger[]
  flight                Flight                 @relation(fields: [flightId], references: [id])

  @@unique([flightId, cabinClass])
  @@map("flight_classes")
  @@schema("catalog")
}

model ReservationPassenger {
  id             String             @id @default(cuid())
  reservationId  String             @map("reservation_id")
  flightClassId  String             @map("flight_class_id")
  firstName      String             @map("first_name")
  lastName       String             @map("last_name")
  documentNumber String             @map("document_number")
  seatNumber     String?            @map("seat_number")
  extraServices  PassengerService[]
  flightClass    FlightClass        @relation(fields: [flightClassId], references: [id])
  reservation    Reservation        @relation(fields: [reservationId], references: [id])
  boardingPasses BoardingPass?

  @@unique([flightClassId, seatNumber], map: "reservation_passengers_flight_class_seat_unique")
  @@map("reservation_passengers")
  @@schema("booking")
}

model PassengerService {
  id                 String               @id @default(cuid())
  passengerId        String               @map("passenger_id")
  serviceConfigId    String               @map("service_config_id")
  quantity           Int                  @default(1)
  unitPriceAtBooking Decimal              @map("unit_price_at_booking") @db.Decimal(10, 2)
  passenger          ReservationPassenger @relation(fields: [passengerId], references: [id])
  serviceConfig      AirlineServiceConfig @relation(fields: [serviceConfigId], references: [id])

  @@map("passenger_services")
  @@schema("booking")
}

model Promotion {
  id            String        @id @default(cuid())
  code          String        @unique
  discountType  DiscountType  @map("discount_type")
  discountValue Decimal       @map("discount_value") @db.Decimal(10, 2)
  maxUsages     Int?          @map("max_usages")
  currentUsages Int           @default(0) @map("current_usages")
  isActive      Boolean       @default(true) @map("is_active")
  reservations  Reservation[]

  @@map("promotions")
  @@schema("booking")
}

model Payment {
  id            String      @id @default(cuid())
  reservationId String      @unique @map("reservation_id")
  amount        Decimal     @db.Decimal(10, 2)
  provider      String
  transactionId String      @map("transaction_id")
  status        String
  createdAt     DateTime    @default(now()) @map("created_at")
  invoice       Invoice?
  reservation   Reservation @relation(fields: [reservationId], references: [id])

  @@map("payments")
  @@schema("payments")
}

model BoardingPass {
  id            String               @id @default(cuid())
  passengerId   String               @unique @map("passenger_id")
  segmentId     String               @map("segment_id")
  boardingCode  String               @unique @map("boarding_code")
  gate          String?
  boardingGroup String?              @map("boarding_group")
  checkInAt     DateTime?            @map("check_in_at")
  status        CheckInStatus        @default(NOT_CHECKED_IN)
  passenger     ReservationPassenger @relation(fields: [passengerId], references: [id])
  segment       Segment              @relation(fields: [segmentId], references: [id])

  @@map("boarding_passes")
  @@schema("checkin")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?  @map("user_id")
  action    String
  entity    String
  entityId  String   @map("entity_id")
  oldData   Json?    @map("old_data")
  newData   Json?    @map("new_data")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")
  user      User?    @relation(fields: [userId], references: [id])

  @@map("audit_logs")
  @@schema("audit")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model aircrafts {
  id           String     @id @default(dbgenerated("(gen_random_uuid())::text"))
  airline_id   String
  model_name   String
  registration String     @unique
  has_wifi     Boolean?   @default(false)
  has_usb      Boolean?   @default(false)
  airlines     airlines   @relation(fields: [airline_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  segments     segments[]

  @@schema("public")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model airline_airports {
  airline_id String
  airport_id String
  airlines   airlines @relation(fields: [airline_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  airports   airports @relation(fields: [airport_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([airline_id, airport_id])
  @@schema("public")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model airline_service_configs {
  id                                                           String          @id @default(dbgenerated("(gen_random_uuid())::text"))
  service_id                                                   String
  airline_id                                                   String
  origin_airport_id                                            String?
  dest_airport_id                                              String?
  price                                                        Decimal         @db.Decimal(10, 2)
  currency                                                     String?         @default("USD")
  airlines                                                     airlines        @relation(fields: [airline_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  airports_airline_service_configs_dest_airport_idToairports   airports?       @relation("airline_service_configs_dest_airport_idToairports", fields: [dest_airport_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  airports_airline_service_configs_origin_airport_idToairports airports?       @relation("airline_service_configs_origin_airport_idToairports", fields: [origin_airport_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  service_catalog                                              service_catalog @relation(fields: [service_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@schema("public")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model airlines {
  id                      String                    @id @default(dbgenerated("(gen_random_uuid())::text"))
  iata_code               String                    @unique
  name                    String
  logo_url                String?
  country_id              String
  aircrafts               aircrafts[]
  airline_airports        airline_airports[]
  airline_service_configs airline_service_configs[]
  countries               countries                 @relation(fields: [country_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  segments                segments[]

  @@schema("public")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model airports {
  id                                                                          String                    @id @default(dbgenerated("(gen_random_uuid())::text"))
  iata_code                                                                   String                    @unique
  name                                                                        String
  city_id                                                                     String
  timezone                                                                    String
  airline_airports                                                            airline_airports[]
  airline_service_configs_airline_service_configs_dest_airport_idToairports   airline_service_configs[] @relation("airline_service_configs_dest_airport_idToairports")
  airline_service_configs_airline_service_configs_origin_airport_idToairports airline_service_configs[] @relation("airline_service_configs_origin_airport_idToairports")
  cities                                                                      cities                    @relation(fields: [city_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  segments_segments_destination_airport_idToairports                          segments[]                @relation("segments_destination_airport_idToairports")
  segments_segments_origin_airport_idToairports                               segments[]                @relation("segments_origin_airport_idToairports")

  @@schema("public")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model audit_logs {
  id         String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  user_id    String?
  action     String
  entity     String
  entity_id  String
  old_data   Json?
  new_data   Json?
  ip_address String?
  user_agent String?
  created_at DateTime? @default(now()) @db.Timestamp(6)

  @@schema("public")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model cities {
  id         String     @id @default(dbgenerated("(gen_random_uuid())::text"))
  name       String
  country_id String
  iata_code  String?    @unique
  airports   airports[]
  countries  countries  @relation(fields: [country_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@schema("public")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model countries {
  id            String     @id @default(dbgenerated("(gen_random_uuid())::text"))
  name          String     @unique
  iso_code      String     @unique
  phone_code    String?
  currency_code String?
  airlines      airlines[]
  cities        cities[]

  @@schema("public")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model flight_classes {
  id              String      @id @default(dbgenerated("(gen_random_uuid())::text"))
  flight_id       String
  cabin_class     cabin_class
  available_seats Int
  base_price      Decimal     @db.Decimal(10, 2)
  flights         flights     @relation(fields: [flight_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([flight_id, cabin_class])
  @@index([flight_id], map: "idx_flight_classes_flight")
  @@schema("public")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model flights {
  id                       String           @id @default(dbgenerated("(gen_random_uuid())::text"))
  origin_airport_iata      String
  destination_airport_iata String
  departure_date           DateTime         @db.Timestamp(6)
  status                   flight_status?   @default(SCHEDULED)
  flight_classes           flight_classes[]
  segments                 segments[]

  @@index([departure_date], map: "idx_flights_departure")
  @@index([origin_airport_iata, destination_airport_iata], map: "idx_flights_origin_dest")
  @@schema("public")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model segments {
  id                                                 String     @id @default(dbgenerated("(gen_random_uuid())::text"))
  segment_number                                     String
  origin_airport_id                                  String
  destination_airport_id                             String
  departure_datetime                                 DateTime   @db.Timestamp(6)
  arrival_datetime                                   DateTime   @db.Timestamp(6)
  airline_id                                         String
  aircraft_id                                        String?
  estimated_duration                                 Int
  flight_id                                          String?
  aircrafts                                          aircrafts? @relation(fields: [aircraft_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  airlines                                           airlines   @relation(fields: [airline_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  airports_segments_destination_airport_idToairports airports   @relation("segments_destination_airport_idToairports", fields: [destination_airport_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  flights                                            flights?   @relation(fields: [flight_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  airports_segments_origin_airport_idToairports      airports   @relation("segments_origin_airport_idToairports", fields: [origin_airport_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([flight_id], map: "idx_segments_flight")
  @@schema("public")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model service_catalog {
  id                      String                    @id @default(dbgenerated("(gen_random_uuid())::text"))
  name                    String
  code                    String                    @unique
  category                String
  description             String?
  airline_service_configs airline_service_configs[]

  @@schema("public")
}

enum UserRole {
  CUSTOMER
  ADMIN
  SERVICE

  @@schema("public")
}

enum FlightStatus {
  SCHEDULED
  DELAYED
  CANCELLED
  COMPLETED

  @@schema("public")
}

enum CabinClass {
  ECONOMY
  PREMIUM_ECONOMY
  BUSINESS
  FIRST

  @@schema("public")
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  CANCELLED

  @@schema("public")
}

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT

  @@schema("public")
}

enum CheckInStatus {
  NOT_CHECKED_IN
  CHECKED_IN
  BOARDED
  NO_SHOW

  @@schema("public")
}

enum cabin_class {
  ECONOMY
  PREMIUM_ECONOMY
  BUSINESS
  FIRST

  @@schema("public")
}

enum flight_status {
  SCHEDULED
  DELAYED
  CANCELLED
  COMPLETED

  @@schema("public")
}
